# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Web
WEB_PORT=3000

# Model + SAEs
MODEL_NAME=Qwen/Qwen3-8B
SAE_REPO=Qwen/SAE-Res-Qwen3-8B-Base-W64K-L0_50

# Hooked layer indices (residual stream). Comma-separated.
# Plan default: middle-weighted, 13 layers, skip 0/35.
HOOK_LAYERS=2,6,10,14,16,18,20,22,24,26,28,30,34

# Streaming top-K per (layer, token).
STREAM_TOP_K=20

# Generation
TEMPERATURE=0.7
TOP_P=0.8
SEED=42

# Storage
DB_PATH=./data/probes.sqlite
# HF_HOME is intentionally unset; we use the default ~/.cache/huggingface so multiple
# projects can share the model/SAE downloads.

# Behavior
# Local fp16 only; MPS does not support bitsandbytes int8/4bit.
DTYPE=float16
DEVICE=mps
